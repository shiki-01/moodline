{
  "name": "moodline",
  "version": "0.2.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "node scripts/sync-manifest-version.mjs && tsx build.ts",
    "package:zip": "node scripts/package-zip.mjs",
    "package:xpi": "node scripts/package-zip.mjs dist.xpi",
    "package:source": "node scripts/package-source.mjs",
    "build:zip": "npm run build && npm run package:zip",
    "build:firefox": "npm run build && node scripts/package-zip.mjs firedox-dist/dist.zip && node scripts/package-zip.mjs firedox-dist/dist.xpi && node scripts/package-source.mjs firedox-dist/source.zip",
    "preview": "vite preview",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "archiver": "^7.0.1",
    "svelte": "^5.28.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-static-copy": "^2.3.0"
  },
  "dependencies": {
    "@master/css": "2.0.0-rc.69",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0"
  }
}
